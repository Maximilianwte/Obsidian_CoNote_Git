{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", ".firebaserc"],
    "rewrites": [
      { "source": "/auth", "destination": "/index.html" },
      { "source": "/auth/**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
